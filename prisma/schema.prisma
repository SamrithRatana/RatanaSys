// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String     @default("USER")  // matches Role.label
  phone         String?
  title         String?                      // matches JobTitle.label
  manager       String?
  department    String?                      // matches Department.label
  telegramId    String?    @unique
  accounts      Account[]
  sessions      Session[]
  balances      Balances[]
}

enum LeaveStatus {
  PENDING
  APPROVED
  INMODERATION
  REJECTED
}

model LeaveType {
  id          String   @id @default(cuid())
  title       String
  values      String[] @default(["Credit", "Used", "Available"])
  category    String
  description String?
}

model Leave {
  id        String      @id @default(cuid())
  type      String
  year      String      @default("")
  startDate DateTime
  endDate   DateTime
  days      Int
  hours     Float?      @default(0)
  userName  String
  userNote  String?
  tasksLink String?
  userEmail String
  status    LeaveStatus @default(PENDING)
  segments  Json?   
  // Head Department (1st approval)
  headDepartment         String?
  headDepartmentNote     String?
  headDepartmentApproved Boolean?  @default(false)
  headDepartmentAt       DateTime?

  // Manager (2nd / final approval)
  manager         String?
  managerNote     String?
  managerApproved Boolean?  @default(false)
  managerAt       DateTime?

  // Telegram — stores the group message_id so edits/cancels update the original message
  telegramMessageId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Balances {
  id    String @id @default(cuid())
  year  String
  name  String
  email String

  // Annual
  annualCredit        Float? @default(0)
  annualUsed          Float? @default(0)
  annualAvailable     Float? @default(0)

  // Sick
  sickCredit          Float? @default(0)
  sickUsed            Float? @default(0)
  sickAvailable       Float? @default(0)

  // Personal
  personalCredit      Float? @default(0)
  personalUsed        Float? @default(0)
  personalAvailable   Float? @default(0)

  // Maternity
  maternityCredit     Float? @default(0)
  maternityUsed       Float? @default(0)
  maternityAvailable  Float? @default(0)

  // Special
  specialCredit       Float? @default(0)
  specialUsed         Float? @default(0)
  specialAvailable    Float? @default(0)

  // Short leave — hours only, no credit/available cap
  shortUsed           Float? @default(0)

  user User @relation(fields: [email], references: [email], onDelete: Cascade)

  @@unique([email, year])
}

model Events {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
}

// ✅ Dynamic departments — managed by admin from UI
model Department {
  id          String   @id @default(cuid())
  label       String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ✅ Dynamic job titles — managed by admin from UI
model JobTitle {
  id          String   @id @default(cuid())
  label       String   @unique  // e.g. "Senior Developer", "CEO", "HR Manager"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ✅ Dynamic roles — managed by admin from UI (no more hardcoded enum)
model Role {
  id          String   @id @default(cuid())
  label       String   @unique  // e.g. "ADMIN", "USER", "MODERATOR"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Team {
  id          String       @id @default(cuid())
  name        String
  department  String       // matches Department.label
  members     TeamMember[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userEmail String   // matches User.email
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([teamId, userEmail])
}